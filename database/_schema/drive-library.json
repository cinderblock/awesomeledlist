{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/drive-library.json",
  "title": "Drive Library",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "developer": {
      "type": ["string", "null"]
    },
    "hardware": {
      "type": ["string", "null"],
      "description": "Supported hardware platforms (freeform summary)"
    },
    "platforms": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Supported platforms as discrete terms (Arduino, ESP32, ESP8266, Teensy, Raspberry Pi, Linux, Windows, macOS, ...)"
    },
    "language": {
      "type": ["string", "null"],
      "description": "Primary implementation/API language (C++, Python, JavaScript, ...)"
    },
    "license": {
      "type": ["string", "null"],
      "description": "SPDX-style license identifier (MIT, GPL-3.0, LGPL-3.0, ...)"
    },
    "status": {
      "anyOf": [
        { "$ref": "common.json#/definitions/status" },
        { "type": "null" }
      ],
      "description": "active = maintained; end-of-life = archived/unmaintained"
    },
    "supported_ics": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Pixel IC / protocol names the library can drive, as stated by its docs (WS2812, APA102, ...)"
    },
    "related_pixel_ics": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "IDs of pixel-ics entries this library supports (subset of supported_ics that exist in the database)"
    },
    "features": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    },
    "youtube_url": {
      "type": ["string", "null"]
    },
    "instructional_resources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
