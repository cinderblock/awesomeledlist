{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/microboard.json",
  "title": "DIY MicroBoard",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "manufacturer": {
      "type": ["string", "null"]
    },
    "soc": {
      "type": ["string", "null"]
    },
    "cpu": {
      "type": ["string", "null"]
    },
    "isa": {
      "type": ["string", "null"]
    },
    "clock_speed": {
      "type": ["number", "null"],
      "unit": "MHz",
      "description": "CPU clock speed in MHz"
    },
    "flash": {
      "type": ["number", "string", "null"],
      "unit": "kB",
      "description": "Onboard program flash in kB (null for SBCs that boot from the storage field; UI humanizes to MB/GB). Strings only for variant lists."
    },
    "ram": {
      "type": ["number", "string", "null"],
      "unit": "kB",
      "description": "RAM in kB (UI humanizes to MB/GB). Strings only for variant lists or qualified values."
    },
    "linux": {
      "type": ["boolean", "null"]
    },
    "max_outputs": {
      "type": ["integer", "null"]
    },
    "min_input_voltage": {
      "type": ["number", "null"],
      "unit": "V",
      "description": "Minimum supply voltage in volts"
    },
    "max_input_voltage": {
      "type": ["number", "null"],
      "unit": "V",
      "description": "Maximum supply voltage in volts"
    },
    "gpio_voltage": {
      "type": ["number", "null"],
      "unit": "V",
      "description": "GPIO logic level in volts"
    },
    "usb": {
      "type": ["string", "null"]
    },
    "ttl_serial": {
      "type": ["boolean", "string", "null"]
    },
    "wifi": {
      "type": ["string", "boolean", "null"]
    },
    "poe": {
      "type": ["boolean", "string", "null"]
    },
    "ethernet": {
      "type": ["string", "boolean", "null"]
    },
    "bluetooth": {
      "type": ["string", "boolean", "null"]
    },
    "storage": {
      "type": ["string", "null"]
    },
    "bms": {
      "type": ["string", "null"]
    },
    "imu": {
      "type": ["boolean", "string", "null"]
    },
    "price": {
      "type": ["string", "number", "null"]
    },
    "release_year": {
      "type": ["integer", "null"]
    },
    "url": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
