{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/common.json",
  "definitions": {
    "status": {
      "type": "string",
      "enum": [
        "active",
        "discontinued",
        "end-of-life",
        "limited",
        "beta",
        "unknown"
      ]
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "image": {
      "description": "Filename of image in the images/ subdirectory",
      "type": ["string", "null"]
    },
    "images": {
      "description": "Array of image filenames in the images/ subdirectory",
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "price": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        { "type": "string", "pattern": "^\\$?[0-9,]+\\.?[0-9]*$" },
        { "type": "string", "enum": ["free", "varies", "contact", "unknown"] }
      ]
    },
    "voltage": {
      "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*\\s*V?$" }]
    },
    "current": {
      "oneOf": [
        { "type": "number" },
        { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*\\s*(m?A)?$" }
      ]
    },
    "year": {
      "oneOf": [{ "type": "integer", "minimum": 1990, "maximum": 2030 }, { "type": "null" }]
    },
    "datasheet_mirror": {
      "type": ["object", "null"],
      "description": "Repo-managed copy of the datasheet, hosted on R2. Written by CI (scripts/mirror-datasheets.ts) - do not edit by hand. The original author/source stays in datasheet_url.",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Public URL of the mirrored PDF on R2"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 of the mirrored file"
        },
        "retrieved": {
          "type": "string",
          "format": "date",
          "description": "Date the file was fetched from the source"
        },
        "source": {
          "type": "string",
          "format": "uri",
          "description": "Exact URL the mirror was fetched from (datasheet_url at fetch time; a changed datasheet_url triggers re-mirroring)"
        }
      },
      "required": ["url", "sha256", "retrieved", "source"],
      "additionalProperties": false
    }
  }
}
