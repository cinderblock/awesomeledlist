{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/pixel-ic.json",
  "title": "Pixel IC",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "pwm_frequency": {
      "type": ["string", "number", "null"]
    },
    "channels": {
      "type": ["integer", "null"]
    },
    "channel_bits": {
      "type": ["integer", "string", "null"]
    },
    "aggregate_bits": {
      "type": ["integer", "string", "null"]
    },
    "clocked": {
      "type": ["boolean", "null"]
    },
    "data_bitrate": {
      "type": ["string", "null"]
    },
    "pixel_data_size": {
      "type": ["string", "null"]
    },
    "pixel_rate_max": {
      "type": ["string", "null"]
    },
    "output_voltage": {
      "type": ["string", "number", "null"]
    },
    "supply_voltage": {
      "type": ["string", "number", "null"]
    },
    "gpio_min": {
      "type": ["string", "number", "null"]
    },
    "gpio_max": {
      "type": ["string", "number", "null"]
    },
    "max_current": {
      "type": ["string", "number", "null"]
    },
    "quiescent_current": {
      "type": ["string", "number", "null"]
    },
    "package_size": {
      "type": ["string", "null"]
    },
    "pin_count": {
      "type": ["integer", "string", "null"]
    },
    "data_type": {
      "type": ["string", "null"]
    },
    "backup_data_line": {
      "type": ["boolean", "null"]
    },
    "max_pixels_per_string": {
      "type": ["integer", "string", "null"]
    },
    "release_year": {
      "type": ["integer", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "third_party_testing": {
      "type": ["string", "null"]
    },
    "datasheet_url": {
      "type": ["string", "null"]
    },
    "other_links": {
      "type": ["string", "null"]
    }
  }
}
